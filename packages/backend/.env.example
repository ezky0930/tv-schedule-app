# 백엔드 환경 변수 예시.
# 이 파일을 복사해서 `.env` 를 만들고 값을 채운다:  cp .env.example .env
#
# ⚠️ .env 는 절대 git 에 커밋하지 말 것 (.gitignore 에 포함됨)
# ⚠️ TMDB API 키는 백엔드에만 두고 프론트엔드에 노출하지 말 것

# API 서버 포트
PORT=4000

# CORS 허용 오리진 (웹앱 개발 서버 주소). 콤마로 여러 개 지정 가능.
CORS_ORIGIN=http://localhost:5173

# TMDB API 키 (Phase 2에서 사용)
# 발급 방법은 README.md 참고. v3 API 키 또는 v4 read access token 중 하나를 넣는다.
TMDB_API_KEY=
# 'v3' (api_key 쿼리) 또는 'v4' (Bearer 토큰) — 위 키 종류에 맞춰 지정
TMDB_AUTH_MODE=v4
